rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Settings Collection
    match /user_settings/{userId} {
      allow get, list, create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Recipes Collection
    match /recipes/{recipeId} {
      function isValidRecipe(data) {
        return data.title is string && data.title.size() <= 200 &&
               data.ownerId == request.auth.uid &&
               data.ingredients is list &&
               data.steps is list;
      }

      allow get: if isSignedIn() && isOwner(resource.data.ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidRecipe(request.resource.data) && 
                      isValidId(recipeId) &&
                      request.resource.data.createdAt == request.time;
                      
      allow update: if isSignedIn() && isOwner(resource.data.ownerId) && 
                      isValidRecipe(request.resource.data) &&
                      request.resource.data.updatedAt == request.time &&
                      request.resource.data.ownerId == resource.data.ownerId &&
                      request.resource.data.createdAt == resource.data.createdAt;
                      
      allow delete: if isSignedIn() && isOwner(resource.data.ownerId);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}